# ═══════════════════════════════════════════════════════════
# Valkey AI Support Copilot — Environment Variables
# Build Beyond Limits Hackathon | Powered by Valkey
# ═══════════════════════════════════════════════════════════

# ── Valkey Connection ────────────────────────────────────────
# Use valkey/valkey-bundle:9-alpine (includes JSON, Search, Bloom, Geo)
#   docker pull valkey/valkey-bundle:9-alpine
#   docker run -d --name valkey -p 6379:6379 valkey/valkey-bundle:9-alpine
VALKEY_URL=redis://localhost:6379
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=

# ── Groq API (optional — enables LLM-powered resolution) ────
# Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── API Configuration ────────────────────────────────────────
# Backend runs on port 8000, frontend on port 3000
# Frontend proxies /api/* to backend automatically via Vite
API_HOST=0.0.0.0
API_PORT=8000

# ── Tawk.to (Human Escalation Layer) ────────────────────────
# Get these from: https://dashboard.tawk.to → Administration → Chat Widget
# The embed URL format is: https://embed.tawk.to/{propertyId}/{widgetId}
VITE_TAWK_PROPERTY_ID=your_property_id_here
VITE_TAWK_WIDGET_ID=default
